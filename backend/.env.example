# Database configuration
# Set this to connect to your Neon / Vercel Postgres database in real-time mode.
# If left blank or commented out, the backend falls back to local static JSON files.
DATABASE_URL=postgres://your_neon_db_user:password@your_neon_db_host/dbname?sslmode=require

# (Optional) Vercel Edge Config & KV fallbacks if you want to sync mock files with those services
# EDGE_CONFIG=https://edge-config.vercel.com/...
# KV_REST_API_URL=https://...
# KV_REST_API_TOKEN=...
